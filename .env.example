# ─────────────────────────────────────────────────────────────────────────────
# Recall — AI Configuration
#
# HOW IT WORKS:
#   Recall uses ONE embedding model for semantic search (recall ask).
#   Every provider below speaks the OpenAI protocol — it's plug and play.
#   No config = keyword search always works as fallback.
#
# UNIVERSAL PATTERN (works with any provider):
#   RECALL_BASE_URL=https://your-provider.com/v1
#   RECALL_API_KEY=your-key
#   RECALL_EMBEDDING_MODEL=provider/model-name
#
# NAMED SHORTCUTS (auto-detected from API key env vars — no base URL needed):
#   OPENROUTER_API_KEY, OPENAI_API_KEY, GOOGLE_GENERATIVE_AI_API_KEY,
#   COHERE_API_KEY, OLLAMA_HOST
# ─────────────────────────────────────────────────────────────────────────────


# ─── Universal Config (optional — used for custom/unlisted providers) ─────────

# RECALL_BASE_URL=https://your-provider.com/v1
# RECALL_API_KEY=your-key-here
# RECALL_EMBEDDING_MODEL=model-name-here


# ═════════════════════════════════════════════════════════════════════════════
# OPTION A — OpenRouter  (200+ models, one key, free tier available)
# https://openrouter.ai/keys
#
# EMBEDDING NOTE: Use openai/* models for embeddings — most open/chat models
# on OpenRouter don't expose an embeddings endpoint. For chat models (Gemma,
# Llama, Claude, GPT, Mistral, etc.) use OpenRouter freely.
# ═════════════════════════════════════════════════════════════════════════════

# OPENROUTER_API_KEY=sk-or-v1-...

# Free embedding model via OpenRouter:
# RECALL_EMBEDDING_MODEL=openai/text-embedding-3-small

# Example free chat models (future recall reasoning features):
#   google/gemma-3-12b-it:free
#   meta-llama/llama-4-scout:free
#   mistralai/mistral-7b-instruct:free
#   deepseek/deepseek-r1:free

# Example paid models via OpenRouter:
#   openai/gpt-4o
#   anthropic/claude-opus-4
#   google/gemini-2.5-pro
#   x-ai/grok-3


# ═════════════════════════════════════════════════════════════════════════════
# OPTION B — Ollama  (fully local, no API key, no cost, privacy-first)
# https://ollama.com — install, then: ollama serve
#
# EMBEDDING NOTE: Chat models (Gemma 4, Llama, etc.) don't expose an embeddings
# API. Pull a dedicated embed model alongside your chat model.
# ═════════════════════════════════════════════════════════════════════════════

# OLLAMA_HOST=http://localhost:11434

# Pull these before using:
#   ollama pull nomic-embed-text     ← embeddings (use this for recall ask)
#   ollama pull mxbai-embed-large    ← higher accuracy embeddings
#   ollama pull gemma3:27b           ← Google Gemma 3 27B (chat)
#   ollama pull gemma4:12b           ← Google Gemma 4 (chat, April 2026)
#   ollama pull llama4               ← Meta Llama 4 (chat)

# Set embedding model (defaults to nomic-embed-text):
# RECALL_EMBEDDING_MODEL=nomic-embed-text


# ═════════════════════════════════════════════════════════════════════════════
# OPTION C — OpenAI  (paid, highest quality embeddings)
# https://platform.openai.com/api-keys
# ═════════════════════════════════════════════════════════════════════════════

# OPENAI_API_KEY=sk-...

# Models:
#   text-embedding-3-small  ← fast, cheap, recommended default
#   text-embedding-3-large  ← highest quality, more expensive


# ═════════════════════════════════════════════════════════════════════════════
# OPTION D — Anthropic  (no native embeddings — use via OpenRouter instead)
# For Claude models, set OPENROUTER_API_KEY and use anthropic/* model IDs.
# ═════════════════════════════════════════════════════════════════════════════

# Via OpenRouter:
# OPENROUTER_API_KEY=sk-or-v1-...
# RECALL_EMBEDDING_MODEL=openai/text-embedding-3-small   ← embeddings
# (Claude is used for chat/reasoning, OpenAI provides the embeddings)


# ═════════════════════════════════════════════════════════════════════════════
# OPTION E — Google Generative AI  (direct, paid)
# https://aistudio.google.com/app/apikey
# ═════════════════════════════════════════════════════════════════════════════

# GOOGLE_GENERATIVE_AI_API_KEY=AIzaSy...

# Models:
#   text-embedding-004  ← recommended


# ═════════════════════════════════════════════════════════════════════════════
# OPTION F — Cohere  (paid, strong multilingual embeddings)
# https://dashboard.cohere.com/api-keys
# ═════════════════════════════════════════════════════════════════════════════

# COHERE_API_KEY=co-...

# Models:
#   embed-english-v3.0       ← English only
#   embed-multilingual-v3.0  ← 100+ languages


# ═════════════════════════════════════════════════════════════════════════════
# OPTION G — GLM / Zhipu AI  (Chinese provider, OpenAI-compat)
# https://open.bigmodel.cn
# ═════════════════════════════════════════════════════════════════════════════

# RECALL_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# RECALL_API_KEY=your-zhipu-key
# RECALL_EMBEDDING_MODEL=embedding-3


# ═════════════════════════════════════════════════════════════════════════════
# OPTION H — MiniMax  (OpenAI-compat)
# https://www.minimaxi.com
# ═════════════════════════════════════════════════════════════════════════════

# RECALL_BASE_URL=https://api.minimax.chat/v1
# RECALL_API_KEY=your-minimax-key
# RECALL_EMBEDDING_MODEL=embo-01


# ═════════════════════════════════════════════════════════════════════════════
# OPTION I — Azure OpenAI  (enterprise)
# Requires: bun add @ai-sdk/azure
# ═════════════════════════════════════════════════════════════════════════════

# RECALL_AI_PROVIDER=azure
# RECALL_AZURE_RESOURCE_NAME=your-resource-name
# RECALL_API_KEY=your-azure-key
# RECALL_EMBEDDING_MODEL=text-embedding-3-small


# ═════════════════════════════════════════════════════════════════════════════
# OPTION J — Local ONNX  (in-process, no server, no key, ~22MB download)
# Requires: bun add @xenova/transformers
# Model downloads automatically on first run.
# ═════════════════════════════════════════════════════════════════════════════

# RECALL_AI_PROVIDER=local


# ═════════════════════════════════════════════════════════════════════════════
# OPTION K — Disable AI  (keyword search only, zero setup, always works)
# ═════════════════════════════════════════════════════════════════════════════

# RECALL_AI_PROVIDER=none


# ─────────────────────────────────────────────────────────────────────────────
# QUICK REFERENCE — Config Resolution Priority
#
#  1. RECALL_BASE_URL set          → custom endpoint, any OpenAI-compat provider
#  2. RECALL_AI_PROVIDER set       → use that named provider explicitly
#  3. OPENROUTER_API_KEY found     → OpenRouter (auto)
#  4. OPENAI_API_KEY found         → OpenAI direct (auto)
#  5. GOOGLE_GENERATIVE_AI_API_KEY → Google (auto)
#  6. COHERE_API_KEY found         → Cohere (auto)
#  7. OLLAMA_HOST set              → Ollama local server (auto)
#  8. nothing set                  → Local ONNX (in-process)
#  9. @xenova/transformers missing → Keyword search (noop)
# ─────────────────────────────────────────────────────────────────────────────
