{
  "name": "recall-cli",
  "version": "0.1.0",
  "description": "Your terminal remembers what you forget.",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "recall": "src/index.ts"
  },
  "workspaces": [
    "landing"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile bin/recall && ./scripts/sign-macos.sh bin/recall",
    "test": "bun test",
    "lint": "tsc --noEmit",
    "clean": "rm -rf bin/ node_modules/",
    "landing:dev": "cd landing && bun run dev",
    "landing:build": "cd landing && bun run build",
    "landing:preview": "cd landing && bun run preview"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/cohere": "^3.0.30",
    "@ai-sdk/google": "^3.0.63",
    "@ai-sdk/openai": "^3.0.53",
    "ai": "^6.0.164",
    "cac": "^6.7.14",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.5",
    "typescript": "^5.7.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "license": "MIT",
  "author": "Bharath",
  "repository": {
    "type": "git",
    "url": "https://github.com/bharath/recall-cli"
  },
  "keywords": [
    "cli",
    "terminal",
    "history",
    "memory",
    "developer-tools",
    "shell",
    "productivity"
  ]
}
