<section class="py-24 px-4 border-t border-slate/50">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold font-mono text-cloud mb-4 text-balance reveal">
        From install to insight in 60 seconds
      </h2>
      <p class="text-dust text-lg max-w-2xl mx-auto text-pretty reveal">
        No accounts. No cloud. One shell hook and you're done.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 relative">
      <!-- Connector line (desktop only) -->
      <div class="hidden md:block absolute top-12 left-[16.67%] right-[16.67%] h-px bg-gradient-to-r from-cyan/30 via-mint/30 to-cyan/30"></div>

      <!-- Step 1 -->
      <div class="relative text-center reveal">
        <div class="w-24 h-24 mx-auto mb-6 rounded-2xl bg-slate/30 border border-slate flex items-center justify-center relative z-10">
          <span class="text-3xl font-bold font-mono text-cyan">01</span>
        </div>
        <h3 class="text-lg font-bold font-mono text-cloud mb-3">Install the hook</h3>
        <p class="text-dust text-sm leading-relaxed max-w-xs mx-auto">
          <code class="text-cloud font-mono text-xs bg-slate/50 px-1.5 py-0.5 rounded">recall init</code>
          prints the one-liner for your shell rc. Or use
          <code class="text-cloud font-mono text-xs bg-slate/50 px-1.5 py-0.5 rounded">--auto</code>
          for idempotent append. zsh and bash supported.
        </p>
      </div>

      <!-- Step 2 -->
      <div class="relative text-center reveal">
        <div class="w-24 h-24 mx-auto mb-6 rounded-2xl bg-slate/30 border border-slate flex items-center justify-center relative z-10">
          <span class="text-3xl font-bold font-mono text-cyan">02</span>
        </div>
        <h3 class="text-lg font-bold font-mono text-cloud mb-3">Work normally</h3>
        <p class="text-dust text-sm leading-relaxed max-w-xs mx-auto">
          Every command is captured silently with repo, cwd, exit code, and duration.
          Imported shell history is enriched automatically. No friction. No prompts.
        </p>
      </div>

      <!-- Step 3 -->
      <div class="relative text-center reveal">
        <div class="w-24 h-24 mx-auto mb-6 rounded-2xl bg-slate/30 border border-slate flex items-center justify-center relative z-10">
          <span class="text-3xl font-bold font-mono text-mint">03</span>
        </div>
        <h3 class="text-lg font-bold font-mono text-cloud mb-3">Find anything</h3>
        <p class="text-dust text-sm leading-relaxed max-w-xs mx-auto">
          <code class="text-cloud font-mono text-xs bg-slate/50 px-1.5 py-0.5 rounded">recall search</code>,
          <code class="text-cloud font-mono text-xs bg-slate/50 px-1.5 py-0.5 rounded">recall project</code>,
          or
          <code class="text-cloud font-mono text-xs bg-slate/50 px-1.5 py-0.5 rounded">recall pick</code>.
          Context-rich results in milliseconds. Never lose a command again.
        </p>
      </div>
    </div>
  </div>
</section>
