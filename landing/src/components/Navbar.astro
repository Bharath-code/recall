---
const githubUrl = 'https://github.com/bharath/recall-cli';
const twitterUrl = 'https://twitter.com/recall_cli';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-ink/80 backdrop-blur-lg border-b border-slate/50">
  <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group active:scale-[0.96] transition-transform duration-150">
      <span class="text-2xl font-mono font-bold text-cyan group-hover:scale-110 transition-transform duration-200 will-change-transform">>_</span>
      <span class="text-xl font-mono font-bold text-cloud group-hover:text-cyan transition-colors duration-200">RECALL</span>
    </a>
    <div class="flex items-center gap-2">
      <a
        href="#features"
        class="hidden sm:inline-flex items-center justify-center min-h-10 min-w-10 px-3 text-dust hover:text-cyan transition-colors duration-200 text-sm font-mono"
      >
        Features
      </a>
      <a
        href={githubUrl}
        class="inline-flex items-center justify-center min-h-10 min-w-10 px-3 text-dust hover:text-cyan transition-colors duration-200 text-sm font-mono"
      >
        GitHub
      </a>
      <a
        href={twitterUrl}
        class="inline-flex items-center justify-center min-h-10 min-w-10 px-3 text-dust hover:text-cyan transition-colors duration-200 text-sm font-mono"
      >
        Twitter
      </a>
    </div>
  </nav>
</header>
