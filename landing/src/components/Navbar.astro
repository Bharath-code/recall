---
const githubUrl = 'https://github.com/bharath/recall-cli';
const twitterUrl = 'https://twitter.com/recall_cli';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-ink/80 backdrop-blur-lg border-b border-slate/50">
  <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="text-2xl font-mono font-bold text-cyan group-hover:scale-110 transition-transform duration-200">>_</span>
      <span class="text-xl font-mono font-bold text-cloud group-hover:text-cyan transition-colors duration-200">RECALL</span>
    </a>
    <div class="flex items-center gap-6">
      <a href={githubUrl} class="text-dust hover:text-cyan transition-all duration-200 text-sm font-mono hover:transform hover:-translate-y-0.5">GitHub</a>
      <a href={twitterUrl} class="text-dust hover:text-cyan transition-all duration-200 text-sm font-mono hover:transform hover:-translate-y-0.5">Twitter</a>
    </div>
  </nav>
</header>
