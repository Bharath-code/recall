<section class="py-24 px-4 border-t border-slate/50">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold font-mono text-cloud mb-4 text-balance reveal">
        How it works
      </h2>
      <p class="text-dust text-lg max-w-2xl mx-auto text-pretty reveal">
        Three simple steps to never forget a command again
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 stagger-children">
      <!-- Capture -->
      <div class="group relative p-8 bg-slate/30 border border-slate rounded-2xl hover:border-cyan/50 transition-[transform,box-shadow,border-color] duration-300 hover:-translate-y-1 reveal">
        <!-- Glow overlay: concentric radius = outer (16px) + bleed (2px) = 18px -->
        <div class="absolute -inset-0.5 bg-gradient-to-r from-cyan to-mint rounded-[18px] opacity-0 group-hover:opacity-20 transition-opacity duration-300 pointer-events-none"></div>
        <div class="relative">
          <div class="w-12 h-12 mb-6 rounded-xl bg-cyan/10 flex items-center justify-center">
            <span class="text-2xl">📝</span>
          </div>
          <h3 class="text-xl font-bold font-mono text-cyan mb-4">CAPTURE</h3>
          <ul class="space-y-3 text-dust text-sm">
            <li class="flex items-start gap-2">
              <span class="text-cyan mt-1">→</span>
              <span>Install hook → every command stored</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-cyan mt-1">→</span>
              <span>zsh precmd + bash PROMPT_COMMAND</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-cyan mt-1">→</span>
              <span>Normalized, deduplicated, local</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Search -->
      <div class="group relative p-8 bg-slate/30 border border-slate rounded-2xl hover:border-cyan/50 transition-[transform,box-shadow,border-color] duration-300 hover:-translate-y-1 reveal">
        <div class="absolute -inset-0.5 bg-gradient-to-r from-cyan to-mint rounded-[18px] opacity-0 group-hover:opacity-20 transition-opacity duration-300 pointer-events-none"></div>
        <div class="relative">
          <div class="w-12 h-12 mb-6 rounded-xl bg-cyan/10 flex items-center justify-center">
            <span class="text-2xl">🔍</span>
          </div>
          <h3 class="text-xl font-bold font-mono text-cyan mb-4">SEARCH</h3>
          <ul class="space-y-3 text-dust text-sm">
            <li class="flex items-start gap-2">
              <span class="text-cyan mt-1">→</span>
              <span>recall search "postgres"</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-cyan mt-1">→</span>
              <span>recall recent --project api</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-cyan mt-1">→</span>
              <span>recall project (git context)</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Recall -->
      <div class="group relative p-8 bg-slate/30 border border-slate rounded-2xl hover:border-cyan/50 transition-[transform,box-shadow,border-color] duration-300 hover:-translate-y-1 reveal">
        <div class="absolute -inset-0.5 bg-gradient-to-r from-cyan to-mint rounded-[18px] opacity-0 group-hover:opacity-20 transition-opacity duration-300 pointer-events-none"></div>
        <div class="relative">
          <div class="w-12 h-12 mb-6 rounded-xl bg-cyan/10 flex items-center justify-center">
            <span class="text-2xl">⚡</span>
          </div>
          <h3 class="text-xl font-bold font-mono text-cyan mb-4">RECALL</h3>
          <ul class="space-y-3 text-dust text-sm">
            <li class="flex items-start gap-2">
              <span class="text-cyan mt-1">→</span>
              <span>Exactly what you ran, where, when</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-cyan mt-1">→</span>
              <span>Exit code, duration, repo context</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-cyan mt-1">→</span>
              <span>Instant search, sub-100ms</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
