---
interface Props {
  lines: string[];
}

const { lines } = Astro.props;
---

<div class="bg-ink/80 backdrop-blur-sm border border-slate rounded-xl overflow-hidden shadow-2xl">
  <!-- Terminal header -->
  <div class="flex items-center gap-2 px-4 py-3 bg-slate/50 border-b border-slate">
    <div class="flex gap-2">
      <div class="w-3 h-3 rounded-full bg-ember"></div>
      <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
      <div class="w-3 h-3 rounded-full bg-mint"></div>
    </div>
    <div class="flex-1 text-center">
      <span class="text-xs text-dust font-mono">recall — zsh</span>
    </div>
  </div>
  
  <!-- Terminal content -->
  <pre class="p-6 font-mono text-sm overflow-x-auto bg-gradient-to-br from-ink/90 to-terminal/90">
    {lines.map((line) => (
      <div class={line.startsWith('$') ? 'text-cyan mb-1' : 'text-cloud mb-1'}>
        {line}
      </div>
    ))}
  </pre>
</div>
