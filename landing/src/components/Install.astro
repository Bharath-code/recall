---
import Terminal from './Terminal.astro';

const installLines = [
  '# One line to start',
  'curl -fsSL https://recall.sh/install | bash',
  '',
  '# Or with Homebrew',
  'brew install recall-cli',
  '',
  '# Then',
  'recall init',
];
---

<section class="py-24 px-4 border-t border-slate/50">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold font-mono text-cloud mb-4">
        Get started in seconds
      </h2>
      <p class="text-dust text-lg">
        One command. No dependencies. Local-first.
      </p>
    </div>
    <Terminal lines={installLines} />
  </div>
</section>
