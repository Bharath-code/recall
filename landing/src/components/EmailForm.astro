---
const formspreeEndpoint = import.meta.env.FORMSPREE_ENDPOINT || 'https://formspree.io/f/YOUR_FORM_ID';
---

<form
  action={formspreeEndpoint}
  method="POST"
  class="flex flex-col sm:flex-row gap-4 max-w-lg"
>
  <div class="flex-1 relative">
    <input
      type="email"
      name="email"
      placeholder="your@email.com"
      required
      class="w-full px-5 py-4 bg-slate/50 border border-slate rounded-xl text-cloud placeholder-dust font-mono text-sm focus:outline-none focus:border-cyan focus:ring-2 focus:ring-cyan/20 transition-colors duration-200"
    />
  </div>
  <button
    type="submit"
    class="px-8 py-4 bg-gradient-to-r from-cyan to-mint text-ink font-mono font-semibold text-sm rounded-xl hover:from-cyan/90 hover:to-mint/90 hover:shadow-lg hover:shadow-cyan/25 transition-[transform,box-shadow] duration-200 hover:-translate-y-0.5 active:scale-[0.96] will-change-transform"
  >
    Get Early Access →
  </button>
</form>
