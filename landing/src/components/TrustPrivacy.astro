<section class="py-24 px-4 border-t border-slate/50">
  <div class="max-w-6xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: Trust copy -->
      <div class="reveal">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-mint/10 border border-mint/20 mb-6">
          <span class="w-2 h-2 rounded-full bg-mint"></span>
          <span class="text-sm text-mint font-mono">Privacy by design, not by promise</span>
        </div>

        <h2 class="text-3xl sm:text-4xl font-bold font-mono text-cloud mb-6 leading-tight text-balance">
          Your shell history never leaves your machine
        </h2>

        <p class="text-dust text-lg leading-relaxed mb-8 text-pretty">
          Shell history is personal. It contains API keys, server IPs, database URLs, and the exact commands that broke production.
          Recall is built to earn trust before it earns usage.
        </p>

        <div class="space-y-4">
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-lg bg-mint/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <span class="text-mint text-sm">✓</span>
            </div>
            <div>
              <h4 class="text-cloud font-mono font-semibold text-sm mb-1">Local SQLite storage</h4>
              <p class="text-dust text-sm">Everything lives in <code class="text-cloud font-mono text-xs bg-slate/50 px-1.5 py-0.5 rounded">~/.recall/recall.db</code>. No cloud sync. No external API calls in core features.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-lg bg-mint/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <span class="text-mint text-sm">✓</span>
            </div>
            <div>
              <h4 class="text-cloud font-mono font-semibold text-sm mb-1">Zero telemetry</h4>
              <p class="text-dust text-sm">No tracking, no analytics, no hidden network calls. The CLI works entirely offline.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-lg bg-mint/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <span class="text-mint text-sm">✓</span>
            </div>
            <div>
              <h4 class="text-cloud font-mono font-semibold text-sm mb-1">AI is opt-in, not opt-out</h4>
              <p class="text-dust text-sm">Semantic search and embeddings are gated behind <code class="text-cloud font-mono text-xs bg-slate/50 px-1.5 py-0.5 rounded">RECALL_EXPERIMENTAL=1</code>. The CLI works perfectly without them.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-lg bg-mint/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <span class="text-mint text-sm">✓</span>
            </div>
            <div>
              <h4 class="text-cloud font-mono font-semibold text-sm mb-1">Safe hook install</h4>
              <p class="text-dust text-sm">Default mode prints the hook line for manual review. <code class="text-cloud font-mono text-xs bg-slate/50 px-1.5 py-0.5 rounded">--auto</code> is append-only with idempotent detection. No backups destroyed.</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-lg bg-mint/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <span class="text-mint text-sm">✓</span>
            </div>
            <div>
              <h4 class="text-cloud font-mono font-semibold text-sm mb-1">Full deletion control</h4>
              <p class="text-dust text-sm">Delete one command, a time range, or everything with <code class="text-cloud font-mono text-xs bg-slate/50 px-1.5 py-0.5 rounded">recall delete --all --yes</code>. No retention games.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Terminal showing privacy commands -->
      <div class="reveal">
        <div class="relative">
          <div class="absolute -inset-1 bg-gradient-to-r from-mint to-cyan rounded-2xl blur opacity-15"></div>
          <div class="relative bg-ink/80 backdrop-blur-sm rounded-xl overflow-hidden shadow-[0_2px_8px_rgba(0,0,0,0.2),0_8px_32px_rgba(0,0,0,0.3)]">
            <div class="flex items-center gap-2 px-4 py-3 bg-slate/50 border-b border-slate rounded-t-xl">
              <div class="flex gap-2">
                <div class="w-3 h-3 rounded-full bg-ember"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-mint"></div>
              </div>
              <div class="flex-1 text-center">
                <span class="text-xs text-dust font-mono">recall — privacy controls</span>
              </div>
            </div>
            <pre class="p-6 font-mono text-sm overflow-x-auto bg-gradient-to-br from-ink/90 to-terminal/90">
<div class="text-cyan mb-1">$ recall pause</div>
<div class="text-cloud mb-3">Capture paused. No commands will be stored.</div>
<div class="text-cyan mb-1">$ recall ignore add "*password*"</div>
<div class="text-cloud mb-3">Added pattern: *password*</div>
<div class="text-cyan mb-1">$ recall config --set capture_enabled=false</div>
<div class="text-cloud mb-3">capture_enabled = false</div>
<div class="text-cyan mb-1">$ recall delete --all --yes</div>
<div class="text-cloud mb-3">Deleted 12,847 commands. Storage freed.</div>
<div class="text-dust"># Your data. Your rules. Period.</div>
            </pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
