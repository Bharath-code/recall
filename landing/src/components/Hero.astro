---
import Terminal from './Terminal.astro';
import EmailForm from './EmailForm.astro';

const terminalLines = [
  '$ recall search "docker prune"',
  '  docker compose down -v --remove-orphans    ~/projects/api   3d ago  exit:0  2.4s',
  '  docker system prune -af                    ~                2w ago  exit:0  8.1s',
  '',
  '$ recall project',
  '  ⚡ npm run dev                              (last: 4h ago)',
  '  ⚡ git checkout -b feature/auth             (last: 1d ago)',
  '  ⚡ docker compose up -d postgres            (startup pattern)',
  '',
  '$ recall recent --limit 3',
  '  bun test                                   ~/recall         2m ago  exit:0  1.2s',
  '  git push origin main                       ~/recall         5m ago  exit:0  0.8s',
  '  recall search "migration"                  ~/recall         12m ago exit:0  0.1s',
];
---

<section class="relative pt-28 pb-20 px-4 overflow-hidden">
  <!-- Background gradients -->
  <div class="absolute inset-0 bg-gradient-to-br from-ink via-ink to-terminal opacity-60"></div>
  <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-cyan/5 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-mint/5 rounded-full blur-3xl"></div>

  <div class="relative max-w-5xl mx-auto">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate/50 border border-cyan/20 mb-8">
      <span class="w-2 h-2 rounded-full bg-mint animate-pulse"></span>
      <span class="text-sm text-cyan font-mono">Local-first. Zero cloud. Zero accounts.</span>
    </div>

    <!-- Headline -->
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold font-mono text-cloud mb-6 leading-[1.1] text-balance">
      Stop re-Googling commands
      <span class="block text-transparent bg-clip-text bg-gradient-to-r from-cyan to-mint">
        you already ran.
      </span>
    </h1>

    <!-- Subheadline -->
    <p class="text-lg sm:text-xl text-dust mb-10 max-w-2xl leading-relaxed text-pretty">
      Recall captures every command with context — repo, directory, exit code, duration —
      so you find the exact thing you did in <span class="text-cyan font-semibold">under 100ms</span>.
      Your data stays on your machine. Always.
    </p>

    <!-- Email Form -->
    <div class="mb-14">
      <EmailForm />
      <p class="mt-3 text-xs text-dust/70 font-mono">No spam. No account required. Unsubscribe anytime.</p>
    </div>

    <!-- Terminal -->
    <div class="relative">
      <div class="absolute -inset-1 bg-gradient-to-r from-cyan to-mint rounded-2xl blur opacity-20"></div>
      <div class="relative">
        <Terminal lines={terminalLines} />
      </div>
    </div>
  </div>
</section>
