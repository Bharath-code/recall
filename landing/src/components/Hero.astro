---
import Terminal from './Terminal.astro';
import EmailForm from './EmailForm.astro';

const terminalLines = [
  '$ recall search "docker compose"',
  '⚡ docker compose up -d --env-file .env     ~/projects/api   3d ago',
  '⚡ docker compose -f docker.prod.yml up     ~/projects/web   2w ago',
];
---

<section class="relative pt-32 pb-24 px-4 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-ink via-ink to-terminal opacity-50"></div>
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-cyan/5 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-mint/5 rounded-full blur-3xl"></div>

  <div class="relative max-w-5xl mx-auto">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate/50 border border-cyan/20 mb-8">
      <span class="w-2 h-2 rounded-full bg-cyan animate-pulse"></span>
      <span class="text-sm text-cyan font-mono">v0.1 launching April 2026</span>
    </div>

    <!-- Headline -->
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold font-mono text-cloud mb-6 leading-tight text-balance">
      Your terminal remembers
      <span class="block text-transparent bg-clip-text bg-gradient-to-r from-cyan to-mint">
        what you forget.
      </span>
    </h1>

    <!-- Subheadline -->
    <p class="text-xl text-dust mb-12 max-w-2xl leading-relaxed text-pretty">
      Capture every command. Search instantly. Recall exactly what you ran, where, and when. Local-first, privacy-respecting, and blazing fast.
    </p>

    <!-- Terminal -->
    <div class="mb-12 relative">
      <!-- Glow wrapper: concentric radius = inner (12px) + padding gap (4px) = 16px rounded-2xl -->
      <div class="absolute -inset-1 bg-gradient-to-r from-cyan to-mint rounded-2xl blur opacity-20"></div>
      <div class="relative">
        <Terminal lines={terminalLines} />
      </div>
    </div>

    <!-- Email Form -->
    <EmailForm />
  </div>
</section>
